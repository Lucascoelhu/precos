{
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/preco-cheio", "destination": "/preco-cheio.html" },
    { "source": "/preco-oferta", "destination": "/preco-oferta.html" }
  ],
  "routes": [
    {
      "src": "/(.*)\\.html",
      "headers": { "Cache-Control": "no-cache" },
      "continue": true
    },
    {
      "handle": "filesystem"
    }
  ]
}
